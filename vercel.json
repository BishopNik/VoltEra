{
  "version": 2,
  "rewrites": [
    { "source": "/articles/:slug.html", "destination": "/api/article-page?slug=:slug" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/api/:collection/:id", "destination": "/api/[collection]/[id]?collection=:collection&id=:id" }
  ]
}
