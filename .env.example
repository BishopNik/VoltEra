PORT=4000
PUBLIC_SITE_URL=https://www.voltares.pp.ua
GA4_MEASUREMENT_ID=
GOOGLE_SITE_VERIFICATION=
CLARITY_PROJECT_ID=
ANALYTICS_DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret
ADMIN_USER=admin
# Лише початкове створення користувачів у порожній collection users.
# Після першого запуску облікові записи керуються в CRM і зберігаються в MongoDB.
ADMIN_USERS=admin,Kostia,Pasha
ADMIN_PASSWORD=replace-with-a-strong-bootstrap-password
# Production: set MongoDB Atlas connection string and database name.
MONGODB_URI=
MONGODB_DB=ink_energy

# The single notification gateway for new leads, reviews and public questions.
CONTACT_API_URL=https://api-contact-tg.a-nikanorov.workers.dev/api/contact/voltares

# Transactional email: customer copies and commercial proposals.
# Verify voltares.pp.ua (or a sending subdomain) in Resend before production use.
RESEND_API_KEY=
EMAIL_FROM=Voltares <orders@voltares.pp.ua>
EMAIL_REPLY_TO=ink.torg@gmail.com
